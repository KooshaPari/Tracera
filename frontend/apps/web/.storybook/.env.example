# Storybook & Chromatic Environment Configuration
# Copy this file to .env.local and fill in your values for local development

# Chromatic Project Token
# Get this from https://www.chromatic.com/manage
# Format: chroma_xxxxxxxxxxxxxxxxxxxxx
CHROMATIC_PROJECT_TOKEN=chroma_xxxxxxxxxxxxx

# Node environment
NODE_ENV=development

# Storybook configuration
STORYBOOK_PORT=6006

# Chromatic configuration
CHROMATIC_ONLY_CHANGED=false
CHROMATIC_AUTO_ACCEPT=false
CHROMATIC_TRACE_CHANGED=expand
CHROMATIC_DRY=false

# Debug configuration
DEBUG=*:verbose
STORYBOOK_DEBUG=false
