#!/usr/bin/env python3
"""
Zen MCP CLI Entry Point Project-specific CLI for zen-mcp-server.
"""

import sys
from pathlib import Path

# Add pheno-sdk to path
pheno_sdk_path = Path(__file__).parent / "src"
sys.path.insert(0, str(pheno_sdk_path))

from pheno.cli.simple import create_simple_cli


def main():
    """
    Main entry point for Zen CLI.
    """
    return create_simple_cli(Path(__file__).parent)


if __name__ == "__main__":
    sys.exit(main())
