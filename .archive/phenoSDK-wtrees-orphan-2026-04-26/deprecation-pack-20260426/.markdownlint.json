{
  "default": true,
  "extends": [
    "markdownlint-rule-helpers",
    "markdownlint-extension-no-bare-urls",
    "markdownlint-extension-task-list-metadata"
  ],
  "MD001": false,
  "MD002": true,
  "MD003": {
    "style": "atx"
  },
  "MD004": {
    "style": "dash"
  },
  "MD005": true,
  "MD006": {
    "level": 2
  },
  "MD007": {
    "indent": 2
  },
  "MD009": {
    "br_spaces": 2
  },
  "MD010": true,
  "MD011": true,
  "MD012": {
    "maximum": 1
  },
  "MD013": {
    "line_length": 120,
    "heading_line_length": 120,
    "code_block_line_length": 120,
    "code_block_line_length_maximum": 120,
    "heading_line_length_maximum": 120,
    "line_length_maximum": 120
  },
  "MD014": false,
  "MD018": true,
  "MD019": true,
  "MD020": true,
  "MD021": true,
  "MD022": true,
  "MD023": true,
  "MD024": {
    "allow_different_nesting": true
  },
  "MD025": {
    "level": 1
  },
  "MD026": {
    "punctuation": ".,;:!?"
  },
  "MD027": true,
  "MD028": true,
  "MD029": true,
  "MD030": {
    "ol_single": 1,
    "ol_multi": 1,
    "ul_single": 1,
    "ul_multi": true
  },
  "MD031": true,
  "MD032": true,
  "MD033": true,
  "MD034": true,
  "MD035": {
    "style": "asterisk"
  },
  "MD036": true,
  "MD037": true,
  "MD038": true,
  "MD039": true,
  "MD040": true,
  "MD041": true,
  "MD042": true,
  "MD043": true,
  "MD044": {
    "names": [
      "TODO",
      "FIXME",
      "NOTE",
      "WARNING",
      "CAUTION",
      "HACK",
      "XXX",
      "BUG"
    ]
  },
  "MD045": true,
  "MD046": {
    "style": "fenced"
  },
  "MD047": true,
  "MD048": true,
  "MD049": true,
  "MD050": true,
  "MD051": true,
  "MD052": true,
  "MD053": true,
  "MD054": true,
  "MD055": true
}
