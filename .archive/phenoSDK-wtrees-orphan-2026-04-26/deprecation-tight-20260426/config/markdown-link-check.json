{
  "ignorePatterns": [
    { "pattern": "^mailto:" },
    { "pattern": "^tel:" },
    { "pattern": "^#"},
    { "pattern": "^javascript:" }
  ],
  "replacementPatterns": [],
  "timeout": "30s",
  "retryOn429": true,
  "retryCount": 3,
  "aliveStatusCodes": [200, 201, 202, 203, 204, 206, 207, 301, 302, 303, 304, 307, 308]
}
