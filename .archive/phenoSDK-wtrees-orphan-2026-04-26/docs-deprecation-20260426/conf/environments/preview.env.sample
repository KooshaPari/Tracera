# Preview Environment Configuration
# ATOMS-PHENO Infrastructure Migration

# Environment
ENVIRONMENT=preview
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://preview_user:preview_pass@preview-db:5432/atoms_pheno_preview
SCHEMA_SEARCH_PATH=public

# Authentication
WORKOS_CLIENT_ID=preview_client_id
WORKOS_API_KEY=preview_api_key
WORKOS_SECRET_KEY=preview_secret_key
WORKOS_REDIRECT_URI=https://preview.atoms-pheno.com/auth/callback
ALLOWED_DOMAINS=preview.atoms-pheno.com,staging.atoms-pheno.com
ENABLE_SSO=true
ENABLE_MFA=true

# CORS
ALLOWED_ORIGINS=https://preview.atoms-pheno.com,https://staging.atoms-pheno.com
ALLOW_CREDENTIALS=true
CORS_MAX_AGE=7200

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# Monitoring
ENABLE_MONITORING=true
ENABLE_PROFILING=false
ENABLE_DEBUG_TOOLBAR=false

# Testing
PYTEST_DISABLE_PLUGIN_AUTOLOAD=1
PYTHONPATH=.:zen-mcp-server:zen-mcp-server/src

# Performance
ENABLE_BENCHMARKS=true
ENABLE_LOAD_TESTING=false
BENCHMARK_THRESHOLD_MS=500

# Security
SECURITY_HEADERS=true
RATE_LIMITING=true
CSRF_PROTECTION=true

# Logging
LOG_FORMAT=json
LOG_FILE=logs/preview.log
LOG_ROTATION=hourly

# Vercel
VERCEL_ENV=preview
VERCEL_URL=preview.atoms-pheno.com
