# Development Environment Configuration
# ATOMS-PHENO Infrastructure Migration

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql://localhost:5432/atoms_pheno_dev
SCHEMA_SEARCH_PATH=public

# Authentication
WORKOS_CLIENT_ID=dev_client_id
WORKOS_API_KEY=dev_api_key
WORKOS_SECRET_KEY=dev_secret_key
WORKOS_REDIRECT_URI=http://localhost:8000/auth/callback
ALLOWED_DOMAINS=localhost,127.0.0.1
ENABLE_SSO=true
ENABLE_MFA=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Monitoring
ENABLE_MONITORING=true
ENABLE_PROFILING=true
ENABLE_DEBUG_TOOLBAR=true

# Testing
PYTEST_DISABLE_PLUGIN_AUTOLOAD=1
PYTHONPATH=.:zen-mcp-server:zen-mcp-server/src

# Performance
ENABLE_BENCHMARKS=true
ENABLE_LOAD_TESTING=true
BENCHMARK_THRESHOLD_MS=1000

# Security
SECURITY_HEADERS=true
RATE_LIMITING=false
CSRF_PROTECTION=false

# Logging
LOG_FORMAT=detailed
LOG_FILE=logs/development.log
LOG_ROTATION=daily
