[run]
source = .
branch = True
parallel = True
concurrency = multiprocessing.cpu_count()

[report]
show_missing = True
skip_covered = False
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\\bProtocol\\):\n    @(abc\\.)?abstractmethod
    typing.overload
    if TYPE_CHECKING:
    \\.\.\.\s*$

omit =
    */tests/*
    */test/*
    */__tests__/*
    */testing/*
    */venv/*
    */virtualenv/*
    */.venv/*
    */env/*
    */.env/*
    */node_modules/*
    */vendor/*
    */site-packages/*
    */dist-packages/*
    */.tox/*
    */build/*
    */dist/*
    */target/*
    */__pycache__/*
    */.pytest_cache/*
    */.mypy_cache/*
    */.ruff_cache/*
    setup.py
    */migrations/*
    */manage.py
    */wsgi.py
    */asgi.py
    */admin.py
    */apps.py
    */urls.py
    */settings/*.py
    */conftest.py
    */fixtures/*
    examples/*
    docs/*
    scripts/*
    *.test.py
    *_test.py
    test_*.py

[paths]
source =
    src/
    .

[html]
directory = coverage_html_report
title = Coverage Report

[xml]
output = coverage.xml

[json]
output = coverage.json
pretty_print = True

[lcov]
output = lcov.info
