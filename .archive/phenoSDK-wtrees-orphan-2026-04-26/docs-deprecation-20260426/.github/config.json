{
  "workflows": {
    "ci": {
      "enabled": true,
      "triggers": [
        "push",
        "pull_request"
      ],
      "branches": [
        "main",
        "develop"
      ]
    },
    "quality": {
      "enabled": true,
      "triggers": [
        "push"
      ],
      "branches": [
        "main"
      ]
    }
  },
  "environments": {
    "production": {
      "protection_rules": [
        "required_reviewers"
      ],
      "secrets": [
        "DEPLOY_TOKEN"
      ]
    }
  }
}
